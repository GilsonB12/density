# Copie para `.env` e ajuste. O `.env` real é ignorado pelo git.

# Postgres/pgvector (sobe via docker-compose). Deve casar com docker-compose.yml.
# Porta 5433 no host para não colidir com um Postgres já instalado na 5432.
DATABASE_URL=postgresql://density:density@localhost:5433/density

# Provedores (opcionais até a Etapa 2 — geração de embeddings/respostas).
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Modelo de embedding e sua dimensão. A dimensão DEVE bater com a coluna vector(n).
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
